{
  "name": "cloudskill-cli",
  "version": "1.0.0",
  "description": "CLI to install Alibaba Cloud CLI skill for AI coding assistants",
  "type": "module",
  "bin": {
    "cloudskill": "./dist/index.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "dev": "bun run src/index.ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "alibaba",
    "cloud",
    "cli",
    "ecs",
    "oss",
    "aliyun",
    "skill",
    "ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.1.1",
    "prompts": "^2.4.2",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node": "^22.10.1",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.7.2"
  }
}
